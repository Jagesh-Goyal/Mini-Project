# =========================
# Backend configuration
# =========================
DATABASE_URL=sqlite:///./dakshtra.db

# =========================
# Security & Authentication
# =========================
JWT_SECRET_KEY=dakshtra_secure_jwt_key_2024_production_ready_change_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ENFORCE_CSRF=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
LOG_LEVEL=INFO

# Optional LLM advisor integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional external job-posting integration
JOB_POSTING_API_URL=
JOB_POSTING_API_KEY=

# Default bootstrap users (recommended to set)
DEFAULT_ADMIN_EMAIL=admin@dakshtra.com
DEFAULT_ADMIN_PASSWORD=change-admin-password
DEFAULT_HR_EMAIL=hr@dakshtra.com
DEFAULT_HR_PASSWORD=change-hr-password
DEFAULT_EMPLOYEE_EMAIL=employee@dakshtra.com
DEFAULT_EMPLOYEE_PASSWORD=change-employee-password

# =========================
# Frontend configuration
# =========================
VITE_API_BASE_URL=http://127.0.0.1:8000
